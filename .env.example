BOT_TOKEN=1234567890:AAH...

# 3x-ui API Token (Settings → Security → API Token)
XUI_URL=https://127.0.0.1:2053
XUI_TOKEN=токен_из_панели_3x_ui
XUI_INSECURE=true
# Web Base Path из 3x-ui Settings → General (по умолчанию /panel)
XUI_BASE_PATH=/panel

# ЮKassa
YOOKASSA_SHOP_ID=shop_id
YOOKASSA_SECRET_KEY=secret_key
YOOKASSA_RETURN_URL=https://t.me/your_bot

# Subscription
SUB_URL=https://ваш-домен:10882/sub/
SUB_DOMAIN=ваш-домен

# Database
DATABASE_URL=sqlite+aiosqlite:///bot/db.sqlite3

# Pricing
PRICE_30D=100
PRICE_60D=200
PRICE_90D=300
EXTRA_DEVICE_PRICE=30
MAX_DEVICES=10
BASE_DEVICES=3

# Admin
ADMIN_IDS=[123456789, 987654321]
